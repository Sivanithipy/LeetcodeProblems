class Solution {
    public int minSubArrayLen(int target, int[] nums) {
        int n = nums.length;
        int left  = 0;
        int right = 0;
        int sum = 0;
        int max = Integer.MAX_VALUE;
        for(right = 0; right<n;right++)
        {
            sum += nums[right];
            while(sum >= target)
            {
                max = Math.min(max, right-left+1);
                sum -= nums[left];
                left++;
            }
        }
        return max == Integer.MAX_VALUE ? 0 : max;
    }
}
